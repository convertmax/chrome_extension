{
  "manifest_version": 3,
  "name": "Convertmax Event Monitor",
  "version": "1.0",
  "description": "Monitors Convertmax script loads and event requests",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.convertmax.io/*",
    "http://*.convertmax.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected-monitor.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Convertmax Event Monitor",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
} 
